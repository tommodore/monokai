{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$comment": "Monokai canonical palette — source of truth for all generated themes",
  "meta": {
    "name": "Monokai",
    "version": "1.0.0",
    "author": "Wimer Hazenberg (original), community ports",
    "description": "The canonical Monokai color palette. All editor/terminal theme files in this repo derive from these values.",
    "background": "dark"
  },
  "colors": {
    "background":       { "hex": "#272822", "description": "Editor background" },
    "foreground":       { "hex": "#F8F8F2", "description": "Default text" },
    "foreground-emph":  { "hex": "#F8F8F0", "description": "Emphasized text / cursor contrast" },
    "cursor":           { "hex": "#F8F8F0", "description": "Cursor color" },
    "selection":        { "hex": "#49483E", "description": "Text selection background" },
    "line-highlight":   { "hex": "#3E3D31", "description": "Current line highlight" },
    "comment":          { "hex": "#75715E", "description": "Comments / secondary text" },
    "line-number":      { "hex": "#90908A", "description": "Line numbers" },
    "line-number-bg":   { "hex": "#3C3D37", "description": "Line number gutter background" },
    "status-bg":        { "hex": "#64645E", "description": "Status bar background" },
    "status-fg":        { "hex": "#F8F8F2", "description": "Status bar text" },
    "red":              { "hex": "#F92672", "description": "Keywords, statements, preprocessor" },
    "orange":           { "hex": "#FD971F", "description": "Variables, parameters, warnings" },
    "yellow":           { "hex": "#E6DB74", "description": "Strings, labels, markup values" },
    "green":            { "hex": "#A6E22E", "description": "Functions, CSS classes, HTML attributes" },
    "cyan":             { "hex": "#A1EFE4", "description": "Strings (alt), some terminal colors" },
    "blue":             { "hex": "#66D9EF", "description": "Types, identifiers, storage class" },
    "violet":           { "hex": "#AE81FF", "description": "Booleans, numbers, constants" },
    "magenta":          { "hex": "#FD5FF0", "description": "CUA rectangle, some UI accents" },
    "gray":             { "hex": "#474747", "description": "UI element borders / non-text" },
    "ansi-black":       { "hex": "#272822", "description": "ANSI black (terminal)" },
    "ansi-red":         { "hex": "#F92672", "description": "ANSI red (terminal)" },
    "ansi-green":       { "hex": "#A6E22E", "description": "ANSI green (terminal)" },
    "ansi-yellow":      { "hex": "#E6DB74", "description": "ANSI yellow (terminal)" },
    "ansi-blue":        { "hex": "#66D9EF", "description": "ANSI blue (terminal)" },
    "ansi-magenta":     { "hex": "#AE81FF", "description": "ANSI magenta (terminal)" },
    "ansi-cyan":        { "hex": "#A1EFE4", "description": "ANSI cyan (terminal)" },
    "ansi-white":       { "hex": "#F8F8F2", "description": "ANSI white (terminal)" },
    "ansi-bright-black":    { "hex": "#75715E", "description": "ANSI bright black (terminal)" },
    "ansi-bright-red":      { "hex": "#F92672", "description": "ANSI bright red (terminal)" },
    "ansi-bright-green":    { "hex": "#A6E22E", "description": "ANSI bright green (terminal)" },
    "ansi-bright-yellow":   { "hex": "#E6DB74", "description": "ANSI bright yellow (terminal)" },
    "ansi-bright-blue":     { "hex": "#66D9EF", "description": "ANSI bright blue (terminal)" },
    "ansi-bright-magenta":  { "hex": "#AE81FF", "description": "ANSI bright magenta (terminal)" },
    "ansi-bright-cyan":     { "hex": "#A1EFE4", "description": "ANSI bright cyan (terminal)" },
    "ansi-bright-white":    { "hex": "#FFFFFF", "description": "ANSI bright white (terminal)" }
  },
  "aliases": {
    "error":            "red",
    "warning":          "orange",
    "string":           "yellow",
    "function":         "green",
    "keyword":          "red",
    "type":             "blue",
    "constant":         "violet",
    "variable":         "orange",
    "number":           "violet",
    "operator":         "red",
    "preprocessor":     "red",
    "class":            "green",
    "identifier":       "cyan",
    "storage":          "blue",
    "support":          "cyan",
    "invalid":          "red",
    "deprecated":       "orange"
  }
}
